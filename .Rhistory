Q <- matrix(c(
0, 0, 0, 0, 1,
0.7, 0.1, 0.1, 0.1, 0,
0.2, 0.4, 0.2, 0.2, 0,
0.1, 0.1, 0.7, 0.1, 0,
0.2, 0.4, 0.2, 0.2, 0,
0.1, 0.1, 0.1, 0.7, 0
), nrow=6, byrow=TRUE)
rownames(Q) <- 1:6
colnames(Q) <- c("A", "T", "G", "C", 0)
# Sequence to analyze
seq1 <- c("A", "G")
seq2 <- c("G", "A", "T", "A", "C")
forward <- function(P, Q, string) {
# Theory of fixed length strings is to add begin state with 0 emission at the
# beginning of the string and end state with 0 emission at the end of the string.
# To clarify coding, first concatenate 0 at beginning and end of string.
# If the original string has length T, then the new string has length L = T + 2.
# In this case T represents time, and L simply represents the length of the mew string.
string <- c(0, string, 0)
L <- length(string)
N <- nrow(P)
M <- ncol(Q)
F <- matrix(0, nrow=N, ncol=L, dimnames = list(0:(N-1), 0:(L-1)))    ## initialize
#   Set f_0 = [1,0,...,0] (At time 0, we are in state 0 with probablity 1)
F[1,1] <- 1            # NOTE:   index of row/column = rowname/colname + 1
for (t in 1:(L-1)) {
F[,t+1] <- crossprod(P, F[,t]) * Q[,string[t+1]]
}
# crossprod(P, F[,t]) = t(P) %*% F[,t]
# The R manual says crossprod is more efficient.
F
}
F1 <- forward(P, Q, seq1)
print(F1)
prob1 <- F1[1, ncol(F1)]
print(prob1)
F2 <- forward(P, Q, seq2)
print(F2)
prob2 <- F2[1, ncol(F2)]
print(prob2)
##	  D. Watson adapted from code by J. Peltonen
##    F       Nx(L+2) matrix for f(i,t) at each state at each time
##				  NOTE:  here we assume state 0 is beginning and end state
#                 first colummn represents begin state and last column represents end state
#                 f(i,t) represents probability of being in state i at time t
##    P		  NxN matrix for transition probabilities
##            P(i,j)=P(S_t+1=j|S_t=i)
##    Q		  NxM matrix for emission probabilities
##             Q(i,a)=P(x_t=a|S_t=i);
##   alphabet vector = 'ACGT'
##   sequence vector of length L, containing the observations
# Transition Matrix P (states 0, 1, 2)
P <- matrix(c(
0, 0.3, 0.7, 0, 0, 0,
0, 0.7, 0.3, 0, 0, 0,
0, 0, 0, 0.4, 0.6, 0,
0, 0, 0, 0.5, 0.5, 0,
0.5, 0, 0, 0, 0, 0.5,
0.7, 0, 0, 0, 0, 0.3
), nrow=6, byrow=TRUE)
rownames(P) <- colnames(P) <- 1:6
# Emission Matrix Q (rows = states 1, 2, 3, 4, 5, 6; columns = A, T, G, C, 0)
Q <- matrix(c(
0, 0, 0, 0, 1,
0.7, 0.1, 0.1, 0.1, 0,
0.2, 0.4, 0.2, 0.2, 0,
0.1, 0.1, 0.7, 0.1, 0,
0.2, 0.4, 0.2, 0.2, 0,
0.1, 0.1, 0.1, 0.7, 0
), nrow=6, byrow=TRUE)
rownames(Q) <- 1:6
colnames(Q) <- c("A", "T", "G", "C", 0)
# Sequence to analyze
seq1 <- c("A", "G")
seq2 <- c("G", "A", "T", "A", "C")
forward <- function(P, Q, string) {
# Theory of fixed length strings is to add begin state with 0 emission at the
# beginning of the string and end state with 0 emission at the end of the string.
# To clarify coding, first concatenate 0 at beginning and end of string.
# If the original string has length T, then the new string has length L = T + 2.
# In this case T represents time, and L simply represents the length of the mew string.
string <- c(0, string, 0)
L <- length(string)
N <- nrow(P)
M <- ncol(Q)
F <- matrix(0, nrow=N, ncol=L, dimnames = list(0:(N-1), 0:(L-1)))    ## initialize
#   Set f_0 = [1,0,...,0] (At time 0, we are in state 0 with probablity 1)
F[1,1] <- 1            # NOTE:   index of row/column = rowname/colname + 1
for (t in 1:(L-1)) {
F[,t+1] <- crossprod(P, F[,t]) * Q[,string[t+1]]
}
# crossprod(P, F[,t]) = t(P) %*% F[,t]
# The R manual says crossprod is more efficient.
F
}
F1 <- forward(P, Q, seq1)
print(F1)
F2 <- forward(P, Q, seq2)
print(F2)
# 	  D. Watson, adapted from code by J. Peltonen
#     B        Nx(T+2) matrix for b(i,t) at each state at each time
#                 b(i,t) represents probability of the tail of the string
#                 assuming we are in state i at time t
# 				  NOTE:  here we assume state 0 is beginning and end state
#                 first colummn represents begin state
#				  and last column represents end state
#     P		  NxN matrix for transition probabilities
#             P(i,j)=P(S_t+1=j|S_t=i)
#     Q		  NxM matrix for emission probabilities
#              Q(i,a)=P(x_t=a|S_t=i);
#    alphabet vector = 'ACGT'
#    sequence vector of length L, containing the observations
# Transition Matrix P (states 1, 2, 3, 4, 5, 6)
P <- matrix(c(
0, 0.3, 0.7, 0, 0, 0,
0, 0.7, 0.3, 0, 0, 0,
0, 0, 0, 0.4, 0.6, 0,
0, 0, 0, 0.5, 0.5, 0,
0.5, 0, 0, 0, 0, 0.5,
0.7, 0, 0, 0, 0, 0.3
), nrow=6, byrow=TRUE)
rownames(P) <- colnames(P) <- 1:6
# Emission Matrix Q (rows = states 1, 2, 3, 4, 5, 6; columns = A, T, G, C, 0)
Q <- matrix(c(
0, 0, 0, 0, 1,
0.7, 0.1, 0.1, 0.1, 0,
