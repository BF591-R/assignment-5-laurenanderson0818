seq2 <- c("G", "A", "T", "A", "C")
backward <- function(P, Q, string){
# Theory of fixed length strings is to add begin state with 0 emission at the
# beginning of the string and end state with 0 emission at the end of the string
# To clarify coding, we will first concatenate 0 at beginning and end of string
# If the original string has length T, then the new string has length L = T + 2
# In this case T represents time, and L simply represents the length of the new string.
string <- c(0, string, 0)
L <- length(string)
N <- nrow(P)
M <- ncol(Q)
B <- matrix(0, nrow=N, ncol=L)    ## initialize
rownames(B) <- 0:(N-1)  # rownames represent hidden states
colnames(B) <- 0:(L-1)  # column names represent time from 0 to T+1
#   Set b_(L) = [1,1,...,1] (initial b vector in column L)
B[,L] <- 1            # NOTE:   index of row/column = rowname/colname + 1
for (t in L:1) {
B[,t-1] <- P %*% (Q[,string[t]] * B[,t])
}
B
}
print(backward(P, Q, seq1))
print(backward(P, Q, seq2))
