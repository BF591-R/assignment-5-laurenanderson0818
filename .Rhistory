0.1, 0.1, 0.7, 0.1, 0,
0.2, 0.4, 0.2, 0.2, 0,
0.1, 0.1, 0.1, 0.7, 0
), nrow=6, byrow=TRUE)
rownames(Q) <- 1:6
colnames(Q) <- c("A", "T", "G", "C", 0)
# Sequence to analyze
